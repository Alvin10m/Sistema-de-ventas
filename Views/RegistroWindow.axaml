<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SistemaVentas.ViewModels"
        x:Class="SistemaVentas.Views.RegistroWindow"
        x:DataType="vm:RegistroViewModel"
        Title="Registro de Usuario"
        Width="420"
        Height="580"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117">

    <Window.Styles>

        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Botón Cancelar -->
        <Style Selector="Button.cancelar /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#131C2B"/>
            <Setter Property="BorderBrush" Value="#131C2B"/>
        </Style>

        <Style Selector="Button.cancelar:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1B2638"/>
            <Setter Property="BorderBrush" Value="#1B2638"/>
        </Style>

        <!-- Botón Registrarse -->
        <Style Selector="Button.registrar /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1A56DB"/>
            <Setter Property="BorderBrush" Value="#1A56DB"/>
        </Style>

        <Style Selector="Button.registrar:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1746B5"/>
            <Setter Property="BorderBrush" Value="#1746B5"/>
        </Style>

    </Window.Styles>

    <!-- Contenedor principal centrado -->
    <StackPanel Margin="40"
                VerticalAlignment="Center"
                Spacing="16">

        <!-- Título -->
        <TextBlock Text="Crear cuenta"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#e8edf5"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="Completa los datos para registrarte"
                   FontSize="13"
                   Foreground="#5a6a80"
                   HorizontalAlignment="Center"/>

        <!-- Nombre de usuario -->
        <TextBlock Text="NOMBRE DE USUARIO"
                   FontSize="11"
                   Foreground="#7a8fa8"/>

        <TextBox Text="{Binding NombreUsuario}"
                 PlaceholderText="Ej: alvin123"
                 Background="#131c2b"
                 Foreground="#c8d6e8"
                 CornerRadius="10"/>

        <!-- Contraseña -->
        <TextBlock Text="CONTRASEÑA"
                   FontSize="11"
                   Foreground="#7a8fa8"/>

        <TextBox Text="{Binding Contrasena}"
                 PasswordChar="*"
                 PlaceholderText="Mínimo 8 caracteres"
                 Background="#131c2b"
                 Foreground="#c8d6e8"
                 CornerRadius="10"/>

        <!-- Confirmar contraseña -->
        <TextBlock Text="CONFIRMAR CONTRASEÑA"
                   FontSize="11"
                   Foreground="#7a8fa8"/>

        <TextBox Text="{Binding ConfirmarContrasena}"
                 PasswordChar="*"
                 PlaceholderText="Repite tu contraseña"
                 Background="#131c2b"
                 Foreground="#c8d6e8"
                 CornerRadius="10"/>

        <!-- Mensaje -->
        <TextBlock Text="{Binding MensajeError}"
                   Foreground="#f87171"
                   FontSize="13"
                   IsVisible="{Binding HayError}"
                   TextWrapping="Wrap"/>

        <!-- Botones -->
        <StackPanel Orientation="Horizontal"
                    Spacing="10">

            <Button Classes="cancelar"
                    Content="Cancelar"
                    Command="{Binding CancelarCommand}"
                    HorizontalAlignment="Stretch"
                    Background="#131c2b"
                    Foreground="#5a6a80"
                    BorderBrush="#131c2b"/>

            <Button Classes="registrar"
                    Content="Registrarse"
                    Command="{Binding RegistrarCommand}"
                    HorizontalAlignment="Stretch"
                    Background="#1a56db"
                    Foreground="White"
                    BorderBrush="#1a56db"/>

        </StackPanel>

    </StackPanel>

</Window>