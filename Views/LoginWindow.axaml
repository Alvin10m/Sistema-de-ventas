<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SistemaVentas.ViewModels"
        x:Class="SistemaVentas.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Inicio de Sesión"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117">

    <StackPanel Margin="40" VerticalAlignment="Center" Spacing="16">

        <TextBlock Text="Bienvenido"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#e8edf5"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="Ingresa tus credenciales para continuar"
                   FontSize="13"
                   Foreground="#5a6a80"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="NOMBRE DE USUARIO" FontSize="11" Foreground="#7a8fa8"/>
        <TextBox Text="{Binding NombreUsuario}"
                 PlaceholderText="Tu nombre de usuario"
                 Background="#131c2b"
                 Foreground="#c8d6e8"
                 CornerRadius="10"/>

        <TextBlock Text="CONTRASEÑA" FontSize="11" Foreground="#7a8fa8"/>
        <TextBox Text="{Binding Contrasena}"
                 PasswordChar="*"
                 PlaceholderText="Tu contraseña"
                 Background="#131c2b"
                 Foreground="#c8d6e8"
                 CornerRadius="10"/>

        <TextBlock Text="{Binding MensajeError}"
                   Foreground="#f87171"
                   FontSize="13"
                   IsVisible="{Binding HayError}"
                   TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Cancelar"
                    Command="{Binding CancelarCommand}"
                    Background="#131c2b"
                    Foreground="#5a6a80"/>
            <Button Content="Iniciar sesión"
                    Command="{Binding IniciarSesionCommand}"
                    Background="#1a56db"
                    Foreground="White"/>
        </StackPanel>

    </StackPanel>
</Window>