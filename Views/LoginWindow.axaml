<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SistemaVentas.ViewModels"
        x:Class="SistemaVentas.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Inicio de Sesión"
        Width="420"
        Height="420"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117">

    <Window.Styles>

        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- Botón Cancelar -->
        <Style Selector="Button.cancelar /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#131C2B"/>
            <Setter Property="BorderBrush" Value="#131C2B"/>
        </Style>

        <Style Selector="Button.cancelar:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1B2638"/>
            <Setter Property="BorderBrush" Value="#1B2638"/>
        </Style>

        <!-- Botón Iniciar sesión -->
        <Style Selector="Button.iniciar /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1A56DB"/>
            <Setter Property="BorderBrush" Value="#1A56DB"/>
        </Style>

        <Style Selector="Button.iniciar:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1746B5"/>
            <Setter Property="BorderBrush" Value="#1746B5"/>
        </Style>

    </Window.Styles>

    <StackPanel Margin="40"
                VerticalAlignment="Center"
                Spacing="16">

        <TextBlock Text="Bienvenido"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#e8edf5"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="Ingresa tus credenciales para continuar"
                   FontSize="13"
                   Foreground="#5a6a80"
                   HorizontalAlignment="Center"/>

        <TextBlock Text="NOMBRE DE USUARIO"
                   FontSize="11"
                   Foreground="#7a8fa8"/>

        <TextBox Text="{Binding NombreUsuario}"
                 PlaceholderText="Tu nombre de usuario"
                 Background="#131c2b"
                 Foreground="#c8d6e8"
                 CornerRadius="10"/>

        <TextBlock Text="CONTRASEÑA"
                   FontSize="11"
                   Foreground="#7a8fa8"/>

        <TextBox Text="{Binding Contrasena}"
                 PasswordChar="*"
                 PlaceholderText="Tu contraseña"
                 Background="#131c2b"
                 Foreground="#c8d6e8"
                 CornerRadius="10"/>

        <TextBlock Text="{Binding MensajeError}"
                   Foreground="#f87171"
                   FontSize="13"
                   IsVisible="{Binding HayError}"
                   TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal"
                    Spacing="10">

            <Button Classes="cancelar"
                    Content="Cancelar"
                    Command="{Binding CancelarCommand}"
                    Background="#131c2b"
                    Foreground="#5a6a80"
                    BorderBrush="#131c2b"/>

            <Button Classes="iniciar"
                    Content="Iniciar sesión"
                    Command="{Binding IniciarSesionCommand}"
                    Background="#1a56db"
                    Foreground="White"
                    BorderBrush="#1a56db"/>

        </StackPanel>

    </StackPanel>

</Window>